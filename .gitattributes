# Git Attributes for SNAKEIUM
# Ensure consistent line endings and proper file handling

# Text files
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.cfg text eol=lf
*.ini text eol=lf

# Binary files
*.mp3 binary
*.wav binary
*.ogg binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary

# Archive files
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.rar binary

# Python bytecode
*.pyc binary
*.pyo binary
*.pyd binary

# Git LFS for large files (if needed)
# *.mp3 filter=lfs diff=lfs merge=lfs -text
# *.wav filter=lfs diff=lfs merge=lfs -text
